{
  "name": "nexel-backend",
  "version": "0.1.0",
  "description": "Express + MongoDB backend for Nexel system",
  "main": "src/app.js",
  "scripts": {
    "backend:start": "node backend/src/server.js",
    "backend:dev": "nodemon backend/src/server.js",
    "backend:test": "jest",
    "backend:lint": "eslint .",
    "backend:swagger": "node backend/src/swagger.js",
    "frontend:dev": "next dev",
    "start": "npm run backend:start",
    "dev": "concurrently \"npm run backend:dev\" \"npm run frontend:dev\"",
    "test": "npm run backend:test",
    "lint": "npm run backend:lint",
    "swagger": "npm run backend:swagger"
  },
  "engines": {
    "node": ">=22 <23"
  },
  "author": "",
  "license": "MIT",
  "dependencies": {
    "bcrypt": "^6.0.0",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "express-validator": "^7.3.2",
    "framer-motion": "^12.41.0",
    "helmet": "^8.0.0",
    "jsonwebtoken": "^9.0.2",
    "lucide-react": "^1.21.0",
    "mongoose": "^8.5.0",
    "morgan": "^1.10.0",
    "multer": "^1.4.5-lts.1",
    "next": "^16.2.9",
    "pdfjs-dist": "^4.4.168",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-pdf": "^10.4.1",
    "react-pdf-highlighter": "^8.0.0-rc.0",
    "socket.io": "^4.8.3",
    "socket.io-client": "^4.8.3",
    "swagger-ui-express": "^5.0.1",
    "winston": "^3.12.0",
    "yamljs": "^0.3.0"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.3.1",
    "@types/react": "19.2.17",
    "concurrently": "^10.0.3",
    "eslint": "^9.5.0",
    "jest": "^29.7.0",
    "nodemon": "^3.1.0",
    "supertest": "^7.0.0",
    "tailwindcss": "^4.3.1",
    "typescript": "6.0.3"
  },
  "overrides": {
    "pdfjs-dist": "$pdfjs-dist"
  }
}
